# GuardMe Gateway — environment variables
# Copy to .env and adjust for your environment

# Node runtime mode (development | production)
NODE_ENV=development

# Port for the management REST API and WebSocket server
PORT=3000

# Port for the forward proxy (browser traffic inspection)
PROXY_PORT=8080

# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gateway_db?schema=public"


# Secret used to sign JWT session tokens - REQUIRED (long random string)
JWT_SECRET="change-me-super-secret"

# JWT lifetime (30m, 1h..) sets the session cookie expiry
JWT_EXPIRES_IN="30m"

# Name of the HttpOnly session cookie sent to the dashboard and API
COOKIE_NAME="gateway_access_token"

# Set true when serving over HTTPS so the cookie is only sent on secure connections
COOKIE_SECURE=false

# SameSite policy for the session cookie (lax | strict | none)
COOKIE_SAME_SITE="lax"

# Optional cookie domain (empty = current host only)
COOKIE_DOMAIN=""

# Path scope for the session cookie
COOKIE_PATH="/"

# When true, reject sessions when IP or User-Agent changes (fingerprint mismatch)
SESSION_FINGERPRINT_STRICT=true

# Authentication freshness window for sensitive routes (vault, rules), after timeout verify-password is required
REAUTH_TIMEOUT_MINUTES=15

# Argon2id parameters for vault encryption key derivation (separate from login password hash)
VAULT_KDF_MEMORY_COST=19456
VAULT_KDF_TIME_COST=2


# VirusTotal API base URL (v3 REST)
VIRUSTOTAL_API_BASE_URL=https://www.virustotal.com/api/v3

# VirusTotal API key - REQUIRED for reputation scans (never commit a real key)
VIRUSTOTAL_API_KEY=virustotal-api-key

# Maximum total time (milliseconds) allowed for the whole scan process (lookup + submit + poll)
THREAT_SCAN_TIMEOUT_MS=30000

# Delay between VirusTotal analysis status polls (milliseconds)
THREAT_SCAN_POLL_INTERVAL_MS=1500

# When VirusTotal is unavailable: open = allow as UNVERIFIED (default), closed = block
THREAT_FAIL_STRATEGY=open

# In-memory VirusTotal result cache TTL (milliseconds)
THREAT_CACHE_TTL_MS=300000

# Upstream forward timeout when proxying allowed HTTP requests (milliseconds)
PROXY_FORWARD_TIMEOUT_MS=30000

# Warning bypass token lifetime after user proceeds to a suspicious link (minutes)
PROXY_BYPASS_TOKEN_MINUTES=5


# Socket.IO namespace path for live dashboard events // must match frontend wsUrl
WS_NAMESPACE=/events

# Allowed browser origins for REST API CORS (credentials required)
API_CORS_ORIGINS=http://localhost:3000,http://localhost:4200

# Origins for WebSocket CORS (defaults to API_CORS_ORIGINS if unset)
WS_CORS_ORIGINS=http://localhost:3000,http://localhost:4200

# Interval between periodic SYSTEM_STATUS broadcasts to connected clients (milliseconds)
WS_SYSTEM_STATUS_INTERVAL_MS=60000


# Rate-limit window length for general API requests (milliseconds, per client IP)
THROTTLE_TTL_MS=60000

# Maximum general API requests per IP within THROTTLE_TTL_MS
THROTTLE_LIMIT=100

# Maximum auth attempts per IP within THROTTLE_TTL_MS
# Stricter limit for login, register, verify-password (brute-force protection)
THROTTLE_AUTH_LIMIT=5


# Window (in days) for behavior baseline learning
BASELINE_WINDOW_DAYS=7

# Minimum traffic logs count for behavior analysis
BASELINE_MIN_SAMPLE_SIZE=50

# Minimum anomaly score (0-100) before logging ANOMALY_DETECTED
UEBA_ALERT_THRESHOLD=60

# Minimum time between anomaly alerts for the same user (milliseconds)
UEBA_ALERT_COOLDOWN_MS=120000

# How many times current hour requests count must exceed baseline active hour for anomaly
# Is current hour requests count > (average × this)? 
UEBA_VOLUME_SPIKE_MULTIPLIER=3