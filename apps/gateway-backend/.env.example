NODE_ENV=development
PORT=3000
PROXY_PORT=8080

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gateway_db?schema=public"

JWT_SECRET="change-me-super-secret"
JWT_EXPIRES_IN="15m"

COOKIE_NAME="gateway_access_token"
COOKIE_SECURE=false
COOKIE_SAME_SITE="lax"
COOKIE_DOMAIN=""
COOKIE_PATH="/"

SESSION_FINGERPRINT_STRICT=true

REAUTH_TIMEOUT_MINUTES=15

VIRUSTOTAL_API_BASE_URL=https://www.virustotal.com/api/v3
VIRUSTOTAL_API_KEY=virustotal-api-key
# Maximum total time (milliseconds) allowed for the whole scan process (lookup + submit + poll)
THREAT_SCAN_TIMEOUT_MS=30000
# Delay between analysis status polls (milliseconds)
THREAT_SCAN_POLL_INTERVAL_MS=1500

# In-memory VirusTotal result cache TTL (milliseconds)
THREAT_CACHE_TTL_MS=300000
# Upstream forward timeout (milliseconds)
PROXY_FORWARD_TIMEOUT_MS=30000
# Warning bypass token lifetime (minutes)
PROXY_BYPASS_TOKEN_MINUTES=5

WS_NAMESPACE=/events
# Allowed browser origins for REST API CORS and WebSocket
API_CORS_ORIGINS=http://localhost:3000,http://localhost:4200
WS_CORS_ORIGINS=http://localhost:3000,http://localhost:4200
WS_SYSTEM_STATUS_INTERVAL_MS=60000

# API rate limiting (per IP, per window)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
# Stricter limit for /auth/login and /auth/register (brute-force protection)
THROTTLE_AUTH_LIMIT=5
