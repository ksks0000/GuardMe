generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  username     String    @unique
  passwordHash String    @map("password_hash")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastAuthAt   DateTime? @map("last_auth_at")

  sessions    Session[]
  trafficLogs TrafficLog[]

  @@map("users")
}

model Session {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  jwtId          String    @unique @map("jwt_id")
  ipAddress      String    @map("ip_address")
  userAgent      String    @map("user_agent")
  createdAt      DateTime  @default(now()) @map("created_at")
  expiresAt      DateTime  @map("expires_at")
  lastVerifiedAt DateTime  @default(now()) @map("last_verified_at")
  revokedAt      DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jwtId])
  @@map("sessions")
}

model TrafficLog {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  clientIp        String   @map("client_ip")
  url             String
  destinationHost String   @map("destination_host")
  destinationPort Int?     @map("destination_port")
  destinationIp   String?  @map("destination_ip")
  method          String
  verdict         String
  riskScore       Int      @map("risk_score")
  timestamp       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([timestamp])
  @@index([userId, timestamp])
  @@index([verdict])
  @@index([riskScore])
  @@index([clientIp])
  @@index([destinationHost])
  @@map("traffic_logs")
}

model SecurityEvent {
  id        String   @id @default(uuid()) @db.Uuid
  type      String
  severity  String
  message   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([type])
  @@index([severity])
  @@map("security_events")
}
