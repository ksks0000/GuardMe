generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  username     String    @unique
  passwordHash String    @map("password_hash")
  kdfSalt      String    @map("kdf_salt")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastAuthAt   DateTime? @map("last_auth_at")

  sessions         Session[]
  trafficLogs      TrafficLog[]
  firewallRules    FirewallRule[]
  vaultCredentials VaultCredential[]
  securityEvents   SecurityEvent[]

  @@map("users")
}

model Session {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  jwtId          String    @unique @map("jwt_id")
  ipAddress      String    @map("ip_address")
  userAgent      String    @map("user_agent")
  createdAt      DateTime  @default(now()) @map("created_at")
  expiresAt      DateTime  @map("expires_at")
  lastVerifiedAt DateTime  @default(now()) @map("last_verified_at")
  revokedAt      DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jwtId])
  @@map("sessions")
}

model FirewallRule {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String?  @db.VarChar(100)
  ruleType  String   @map("rule_type") @db.VarChar(16)
  pattern   String   @db.VarChar(253)
  action    String   @db.VarChar(16)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, enabled])
  @@map("firewall_rules")
}

model TrafficLog {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  clientIp        String   @map("client_ip")
  url             String
  destinationHost String   @map("destination_host")
  destinationPort Int?     @map("destination_port")
  destinationIp   String?  @map("destination_ip")
  method          String
  policyDecision  String   @map("policy_decision")
  threatVerdict   String   @map("threat_verdict")
  matchedRuleId   String?  @map("matched_rule_id") @db.Uuid
  riskScore       Int      @map("risk_score")
  timestamp       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([timestamp])
  @@index([userId, timestamp])
  @@index([policyDecision])
  @@index([threatVerdict])
  @@index([riskScore])
  @@index([clientIp])
  @@index([destinationHost])
  @@map("traffic_logs")
}

model SecurityEvent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  type      String
  severity  String
  message   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([type])
  @@index([severity])
  @@index([userId, createdAt])
  @@map("security_events")
}

model VaultCredential {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  serviceName       String   @map("service_name") @db.VarChar(120)
  username          String   @db.VarChar(255)
  encryptedPassword String   @map("encrypted_password") @db.Text
  iv                String   @db.VarChar(32)
  authTag           String   @map("auth_tag") @db.VarChar(32)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, serviceName])
  @@map("vault_credentials")
}
